    <selectionEntry id="6d78-faad-79fd-b133" name="Ripper Swarm" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="b3f5-3283-0948-68a6" name="Mindless" hidden="false">
          <description>A ripper swarm never has to fall back and is assumed to automatically pass any Morale checks it is required to take, even against attacks which normally force their target to fall back with no test taken. Rippers cannot be pinned. For the purposed of mission objectives, Ripper Swarms cannot capture table quarters, hold objectives, or count as scoring units.</description>
        </rule>
        <rule id="739d-e2a1-a793-3269" name="Vulnerable to Blasts" hidden="false">
          <description>Template and blast weapons inflict two wounds instead of one on Ripper Swarms</description>
        </rule>
        <rule id="e468-ead0-7b3a-d2c8" name="Small Targets" hidden="false">
          <description>Ripper Swarm&apos;s cover saves are improved by +1.</description>
        </rule>
      </rules>
      <infoLinks>
