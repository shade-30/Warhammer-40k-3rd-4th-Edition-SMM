    <selectionEntry id="bc6b-d4fe-5f23-300f" name="Trygon (IA)" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3261-6601-5bfe-f5d0" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <profiles>
        <profile id="6691-1001-0aba-1f90" name="Bio-electric Field" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon">
          <characteristics>
            <characteristic name="Range" typeId="deb8-131d-bdcf-1376">12&quot;</characteristic>
            <characteristic name="S" typeId="24d8-2110-08fa-d844">4</characteristic>
            <characteristic name="AP" typeId="25ce-028f-0aae-2855">5</characteristic>
            <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Assault D6</characteristic>
            <characteristic name="Abilities" typeId="492d-1f80-b777-26f2"/>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="7d85-f0a1-ca1b-ca9d" name="Bio-electric Field" hidden="false">
          <description>The Trygon generates a potent bio-electric field which it can use in one of two ways: It can either use the field as a defensive barrier, giving it a 6+ invulnerable save, or use it in the shooting phase to attack an enemy unit. Declare at the start of the Trygon&apos;s turn how it will use its field.</description>
        </rule>
        <rule id="cc41-c871-b712-5972" name="Subterranean Tunnels" hidden="false">
          <description>The Trygon is large enough to carve underground tunnels along which other smaller Tyranid creatures can follow,. If the Trygon is Deep Striking, then the Tyranid player may place a single brood of
Gaunts, Hormagaunts, Raveners, or a Ripper Swarm in reserve with the Trygon. Once the Trygon emerges, the Brood will automatically follow in the next turn, moving on to the table from the point where the Trygon arrived. If this means they would enter the table directly into an enemy unit, then they will move on in the assault phase and count as assaulting as normal. 

Such is the Trygon&apos;s size and power that if it emerges within 1&quot; of an enemy model (and would therefore normally be destroyed), it is not destroyed but instead it is placed as normal, move any enemy models out of the way, but still place them in base contact with the Trygon. The Trygon counts as having assaulted the enemy. If the Trygon emerges within 1&quot; of a Super-heavy vehicle or a creature with mass points, then it is destroyed as normal.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="41c7-517a-5cfe-a675" name="Scythe Tail" hidden="false" targetId="7938-f768-2241-140b" type="rule"/>
        <infoLink id="9911-e9e3-0226-ef11" name="Scything Talons" hidden="false" targetId="959a-831b-05aa-b8cf" type="rule">
          <modifiers>
            <modifier type="set" field="name" value="2x Scything Talons"/>
          </modifiers>
        </infoLink>
        <infoLink id="b20e-98bd-c0c6-0ed6" name="Gargantuan Creature" hidden="false" targetId="7163-934b-46dc-56a4" type="rule"/>
        <infoLink id="574c-ac71-445a-4937" name="Scythed Hierodule" hidden="false" targetId="bce5-6322-d3c9-3384" type="profile"/>
        <infoLink id="4fa9-06f2-a29d-592d" name="Fearless" hidden="false" targetId="b137-13a1-eb97-c5e5" type="rule"/>
        <infoLink id="88fc-b253-8652-c9f2" name="Cavalry" hidden="false" targetId="0e80-1d1e-f91a-11fe" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="ca06-ad35-ac34-1b6c" name="Gargantuan Creature" hidden="false" targetId="6e0e-facb-964d-a1c4" primary="false"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="290.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="1824-a915-d1ec-b0ff" name="Meiotic Spores (IA)" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3261-6601-5bfe-f5d0" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <rules>
        <rule id="dfe0-d611-f8af-ece8" name="Mindless" hidden="false">
          <description>A Spore mine cluster never has to fall back and is assumed to automatically pass any Morale checks it is required to take, even against attacks which normally force their target to fall back with no test taken. Spore mine cluster cannot be pinned. For the purposed of mission objectives, Spore mine cluster cannot capture table quarters, hold objectives, or count as scoring units.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="b712-c770-9df6-bb14" name="Deep Strike" hidden="false" targetId="5715-6219-5059-9bcf" type="rule"/>
        <infoLink id="e151-eaf2-252f-3971" name="Spore Mines" hidden="false" targetId="2bcd-07b5-747a-af83" type="rule"/>
        <infoLink id="abb1-2c3d-03d0-2934" name="Spore Mine (Bio Acid)" hidden="false" targetId="0d11-5f87-fd53-ad07" type="profile"/>
        <infoLink id="5626-ffe0-8620-ac0d" name="Spore Mine" hidden="false" targetId="89d9-bbe2-d5d7-7e55" type="profile"/>
      </infoLinks>
      <selectionEntryGroups>
        <selectionEntryGroup id="df41-b917-7bd5-b67e" name="Meiotic Spores" hidden="false" collective="false" import="true" defaultSelectionEntryId="ad86-4c97-562c-3ad8">
          <constraints>
            <constraint field="selections" scope="parent" value="3.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="01e5-a121-7027-a0bd" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="207e-7595-f024-53ff" type="min"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="ad86-4c97-562c-3ad8" name="Meiotic Spore" hidden="false" collective="false" import="true" type="upgrade">
              <rules>
                <rule id="b466-9954-0271-17b9" name="Aerial Attack" hidden="false">
                  <description>If an enemy aircraft enters the board, then the Tyranid player may activate any of his Meiotic Spores that are floating high. Make the aircraft&apos;s attack run as normal; the Meiotic Spores will move 3D6&quot; directly towards the aircraft, at any poin in its attack run. If it comes into contact with the aircraft then it explodes. </description>
                </rule>
                <rule id="ed3c-5c9a-36a2-206c" name="Altitude" hidden="false">
                  <description>Meiotic Spores can float at two levels: Ground or high. At ground level they can only attack other ground units. Floating high they can only attack aircraft. At the start of the game, the Tyranid player must declare which level each of his Spores will float at. A Meiotic Spore will then remain at that level throughout the game.
Meotic Spores floating high will only attack aircraft as they are floating too high to attack enemy units on the ground. They cannot be assaulted by enemy units, unless the unit has jump packs or can fly and any unit targeting them must add 12&quot; to the range required to reach them (as if targeting aircraft). Being slow moving drifters however, a unit uses its normal BS to hit a Meiotic Spore.</description>
                </rule>
                <rule id="b136-be00-171f-1bf2" name="Atmospheric Descent" hidden="false">
                  <description>Spore Mine Clusters must always enter play by Deep Strike, regardless of mission special rules.</description>
                </rule>
                <rule id="7fd1-cc81-f23d-7d34" name="Bio-Acid Payload" hidden="false">
                  <description>If the Meiotic Spore is destroyed by enemy fire, or by self-destructing, then D6-1 Bio-acid Spore Mines are thrown out. Place a Spore Mine on the same spot as the floating spore, then place all the remaining Spore Mines in base contact with the first. These act like a normal Spore Mine Cluster and float at ground level.</description>
                </rule>
                <rule id="1e0c-6549-a248-89fa" name="Mindless" hidden="false">
                  <description>A Meiotic Spore never has to fall back and is assumed to automatically pass any Morale checks it is required to take, even against attacks which normally force their target to fall back with no test taken. Meiotic Spores cannot be pinned. For the purposed of mission objectives, Meiotic Spores cannot capture table quarters, hold objectives, or count as scoring units.</description>
                </rule>
                <rule id="8c6b-4662-2137-7c44" name="Meiotic Spore" hidden="false">
                  <description>Meiotic Spores are taken as a single choice, but are deployed and act independently.
Meiotic Spores drift D6&quot; in a random direction in each Tyranid Movement phase. On a Hit symbol on the scatter dice the Tyranid player may choose the direction of movement. Unlike other models the spore can move within 1&quot; of enemy models, and if they make contact with an enemy model it detonates.
If a Meiotic Spore makes contact with an enemy, or an enemy unit or vehicle shoots while within 2&quot; of it the mine it explodes immediately. It can also be manually detonated in the Tyranid players Shooting phase.
Place a Large Blast Marker centered over the mine exploding (do not scatter this marker) and resolve it as a normal blast weapon.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="327f-c0b8-53ad-d1ea" name="Meiotic Spore" hidden="false" targetId="1f08-8611-7a43-825c" type="profile"/>
                <infoLink id="e83c-0308-816e-fd3f" name="Meiotic Spore" hidden="false" targetId="1b4e-0fe9-7859-a5f9" type="profile"/>
                <infoLink id="5ff7-533c-0b2a-4563" name="Deep Strike" hidden="false" targetId="5715-6219-5059-9bcf" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="35.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="a364-d501-eeaf-b7b4" name="Malanthrope (IA)" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3261-6601-5bfe-f5d0" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <rules>
        <rule id="a5b8-ed38-6a2c-7730" name="Anaphylactic Shock" hidden="false">
          <description>Due to its extreme toxicity, any wound from the Malanthrope cause Instant Death. This does not effect Daemons — as warp beings they are immune to the toxins. This includes C&apos;tan and the Eldar Avatar.</description>
        </rule>
        <rule id="22af-44a8-2f89-c876" name="Multiple Attacks" hidden="false">
          <description>The Malanthrope has a random number of attacks each turn. At the start of each Assault phase roll a D6+1; this is the number of attacks from the Malanthrope&apos;s groping tendrils.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="1659-ce97-733b-4d9a" name="Warp Field" hidden="false" targetId="f50d-26b1-c947-b50d" type="rule"/>
        <infoLink id="8dec-9423-0d5e-3637" name="Synapse Creature" hidden="false" targetId="c531-2ba5-638d-73d5" type="rule"/>
        <infoLink id="a67b-b873-abb2-8823" name="The Horror" hidden="false" targetId="1145-b9af-3e5e-f939" type="rule"/>
        <infoLink id="37ea-d2f5-c614-2be7" name="Shoot the Big Ones!" hidden="false" targetId="e5fa-b52a-258b-5e3d" type="rule"/>
        <infoLink id="c5ba-ae0a-c1af-c78a" name="Fleet of Claw" hidden="false" targetId="e0d3-28a5-37fb-1bb4" type="rule">
          <modifiers>
            <modifier type="set" field="name" value="Fleet of Tendril"/>
          </modifiers>
        </infoLink>
        <infoLink id="80ce-3f40-f5ed-66dd" name="Feeder Tendrils" hidden="false" targetId="eeb5-03a9-e850-3e01" type="rule"/>
        <infoLink id="f321-8d68-ae3c-3878" name="Malanthrope" hidden="false" targetId="ce08-9828-b148-5f1e" type="profile"/>
      </infoLinks>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="140.0"/>
      </costs>
    </selectionEntry>
