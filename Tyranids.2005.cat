    <selectionEntry id="7869-3878-3862-1dfe" name="Zoanthropes" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="10ca-85c7-2b77-1c17" name="Brood" hidden="false">
          <description>You may include between 1 and 3 Zoanthropes as a single Heavy Support choice, but only one choice may be made per army. Thus you can have a maximum of three in an army. They do not need to be placed together, and they operate independently during the game.</description>
