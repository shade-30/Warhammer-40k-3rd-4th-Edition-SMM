    <profile id="406d-fd46-0418-e383" name="Web of Skulls" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Ranged Weapon">
      <characteristics>
        <characteristic name="Range" typeId="deb8-131d-bdcf-1376">24&quot;</characteristic>
        <characteristic name="S" typeId="24d8-2110-08fa-d844">4</characteristic>
        <characteristic name="AP" typeId="25ce-028f-0aae-2855">5</characteristic>
        <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Assault 1</characteristic>
        <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">If the Web of Skulls hits, roll to hit the unit again. Continue rolling until the Web of Skulls misses or 4 hits were inflicted. No model in the target unit may ever be hit twice by this weapon. Additionally, in close combat the Web of Skulls is treated as a power weapon.</characteristic>
      </characteristics>
    </profile>
    <profile id="0d3c-c54b-2d98-d764" name="Sword of Asur" hidden="false" typeId="fa54-3872-dea1-df41" typeName="Melee Weapon">
      <characteristics>
        <characteristic name="Type" typeId="3f50-492d-96d0-69c5">1-H</characteristic>
        <characteristic name="Strength" typeId="1439-1344-a602-f9d9">User</characteristic>
        <characteristic name="Ignores Sv" typeId="1439-1344-a602-f9d8">Yes</characteristic>
        <characteristic name="Abilities" typeId="a46d-26b2-96ab-913f">Re-roll misses to hit. A multi-wound model that suffers a wound from the Sword of Asur must pass a Leadership test or die automatically.</characteristic>
      </characteristics>
    </profile>
    <profile id="39f3-5cae-9dad-1d5b" name="Swooping Hawk Grenade Pack" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Ranged Weapon">
      <characteristics>
        <characteristic name="Range" typeId="deb8-131d-bdcf-1376">n/a</characteristic>
        <characteristic name="S" typeId="24d8-2110-08fa-d844">4</characteristic>
        <characteristic name="AP" typeId="25ce-028f-0aae-2855">5</characteristic>
        <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Large Blast</characteristic>
        <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">When a Swooping Hawk unit uses Deep Strike to deploy, it may also use its grenades. Place the Large Blast marker anywhere on the table and roll a Scatter dice. If the arrow is rollwed, the marker still moves D6&quot; in the indicated direction.</characteristic>
      </characteristics>
    </profile>
    <profile id="edd9-682e-28b9-e212" name="Staff of Ulthamar" hidden="false" typeId="fa54-3872-dea1-df41" typeName="Melee Weapon">
      <characteristics>
        <characteristic name="Type" typeId="3f50-492d-96d0-69c5">2-H</characteristic>
        <characteristic name="Strength" typeId="1439-1344-a602-f9d9">User x2</characteristic>
        <characteristic name="Ignores Sv" typeId="1439-1344-a602-f9d8">Yes</characteristic>
        <characteristic name="Abilities" typeId="a46d-26b2-96ab-913f">Allows Eldrad to cast an additional psychic power (including one he already cast this turn), or can be used in an assault, wounding on 2+ and ignoring armour saves. It cannot be used in both manners in the same turn.</characteristic>
      </characteristics>
    </profile>
    <profile id="b5de-e63c-de80-a7fe" name="Spear of Teuthias (Ranged)" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Ranged Weapon">
