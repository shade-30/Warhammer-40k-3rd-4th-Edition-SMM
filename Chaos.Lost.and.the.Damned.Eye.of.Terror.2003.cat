              </constraints>
              <rules>
                <rule id="3bd6-ccf0-da49-015b" name="Random Attacks" hidden="false">
                  <description>Roll a D6 per spawn at the start of each Assault phase when they are fighting</description>
                </rule>
                <rule id="6c2d-811e-0518-2d49" name="Insanely Stupid" hidden="false">
                  <description>Make a Leadership test for each spawn unit at the start of the Chaos player&apos;s turn. If the test is failed the Spawn do not move that turn and may not assault. Spawn which are already in an assault don&apos;t have to test. Independent characters may not join units of Chaos Spawn.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="cd36-004b-4c96-f13c" name="Daemon Spawn" hidden="false" targetId="65ba-1706-40bb-5078" type="profile"/>
