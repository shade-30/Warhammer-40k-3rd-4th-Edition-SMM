    <selectionEntryGroup id="ad83-1ee9-ea12-cb0b" name="Eldar Vehicle Upgrades" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="613e-e3a4-b0be-0fc1" name="Crystal Targeting Matrix" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="78a4-fd0c-54ca-b61c" type="max"/>
          </constraints>
          <rules>
            <rule id="6022-e12a-7589-6c95" name="Crystal Targeting Matrix" hidden="false">
              <description>The vehicle may shoot during the movement phase rather than the shooting phase. Moving, shooting, and then completing its move. All the normal restrictions apply to the number of weapons that can be fired due to the total distance moved (both before and after shooting).</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="30.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f6cd-6dfe-a20d-e599" name="Holo-field" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="9fd2-b6a5-ad24-557f" value="0.0">
              <conditions>
                <condition field="selections" scope="ancestor" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="d7ab-d578-0ff9-f627" type="instanceOf"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9fd2-b6a5-ad24-557f" type="max"/>
          </constraints>
