    <selectionEntry id="458c-f6c7-3807-f6e3" name="Autarch (Homebrew)" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="16fe-3807-38b8-22a7" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <rules>
        <rule id="b35f-9d80-b351-ca65" name="Adaptability" hidden="false">
          <description>An Autarch cannot join a unit of Swooping Hawks unless he has swooping hawk wings, and cannot join a unit of Warp Spiders unless he has a warp jump generator.
But an Autarch with swooping hawk wings or a warp jump generator may join units without them, but his movement changes to that of the unit joined.
Like normal, an Autarch with a Jetbike may only join other units of Jetbikes, and likewise an Autarch without a jetbike may not join units of jetbikes.</description>
        </rule>
      </rules>
