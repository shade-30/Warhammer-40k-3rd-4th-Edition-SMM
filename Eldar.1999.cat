      <rules>
        <rule id="5c68-72e4-daa0-199a" name="Stelthene Field" hidden="false">
          <description>Enemy models attempting to fire at a model equipped with Stelthene Field count as if firing at night and must roll to check their spotting distance. If the model is not within spotting range the unit misses its chance to fire while searching for a target and so may not choose a different target. If firing at a model equipped with Stelthene Field while the Night Fighting scenario special rules are in effect, the rolled spotting distance cannot be modified or re-rolled. Models equipped with Stelthene Field cannot be the target &quot;free&quot; shots when set up as they are invisible to scanners like auspexes.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="4eb7-a886-f6db-f64b" name="Cameleoline Coating" hidden="false" targetId="8efe-b233-9d76-0257" type="rule"/>
        <infoLink id="b5eb-f369-d0c7-efb6" name="Fearless" hidden="false" targetId="b137-13a1-eb97-c5e5" type="rule"/>
