      <rules>
        <rule id="479b-ab98-5cdd-cd53" name="Strategist" hidden="false">
          <description>An Eldar Pirate Commander is a brilliant strategist, able to adapt to any situation on the battlefield. Once before the game begins, but after initiative has been ceased, the Eldar player may re-reploy the Pirate Commander and any attached squad to a different location within the deployment zone.</description>
        </rule>
      </rules>
