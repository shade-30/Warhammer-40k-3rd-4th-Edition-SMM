          </costs>
        </selectionEntry>
        <selectionEntry id="dbb1-3d00-fcfb-e293" name="Scythes" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b3e0-5228-6b87-7746" type="max"/>
          </constraints>
          <rules>
            <rule id="a08b-1217-d6cb-fda6" name="Scythes" hidden="false">
              <description>Any enemy model that rolls a 1 to hit the vehicle in close combat suffers a Strength 5 hit.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="9735-f0ad-2434-2ba6" name="Spirit Stone" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bcda-2e22-4042-df00" type="max"/>
          </constraints>
          <rules>
            <rule id="69c7-f5a5-853a-87b9" name="Spirit Stone" hidden="false">
              <description>If the vehicle suffers a &apos;crew shaken&apos; result, roll a D6. On a 4+ the vehicle is instead un affected. If the vehicle suffers a &apos;crew stunned&apos; result, roll a D6. On a 4 or 5 treat the result as a &apos;crew shaken&apos; result instead, and on a 6 the result is ignored.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="4777-1d41-f54b-d370" name="Star Engines" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditions>
                <condition field="selections" scope="ancestor" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="98d0-6e45-bbd6-2f5f" type="instanceOf"/>
              </conditions>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3f3c-0890-655f-ffbc" type="max"/>
          </constraints>
          <rules>
            <rule id="8a45-e3f3-f12a-c1cd" name="Star Engines" hidden="false">
              <description>Instead of firing any weapons the vehicle may move 2D6&quot; in a straight line during the shooting phase. A vehicle may not use its star engines in the same turn that it embarks or disembarks units.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="15.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="dfc1-ebc7-51ee-348d" name="Vectored Engines" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="9262-09e2-ec6b-146c" type="max"/>
          </constraints>
          <rules>
            <rule id="47f6-a168-6c97-80df" name="Vectored Engines" hidden="false">
              <description>The vehicle may re-roll any failed Difficult Terrain tests.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="5.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
