      <rules>
        <rule id="4cf7-5c15-1792-3e2f" name="Agile Vehicle" hidden="false">
          <description>Unlike other super heavy vehicles, the Tempest can move up to 6&quot; and fire all weapons or up to 12&quot; and fire one weapon. It may not move more than 12&quot;</description>
        </rule>
        <rule id="414d-8381-fcf5-f415" name="Eldar Fields" hidden="false">
          <description>4+ Invulnerable Save vs Glancing or Penetrating hits on Front and Side facings.</description>
        </rule>
      </rules>
