          <rules>
            <rule id="6310-6e21-bdad-436c" name="Ghostvoice" hidden="false">
              <description>Any Wraithguard unit with a model within 6&quot; of a Spiritseer does not have to test for Wraithsight, just as if a Warlock was accompanying the unit.</description>
            </rule>
