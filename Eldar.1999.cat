        <selectionEntry id="edd8-87c5-b1a4-4892" name="Spiritseer" hidden="false" collective="false" import="true" type="model">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition field="selections" scope="ancestor" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="5271-ffb6-46ff-8c2e" type="notInstanceOf"/>
