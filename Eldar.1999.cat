    <selectionEntry id="f1f6-2982-e227-d67a" name="Exodite Carnosaur" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="72f8-432e-f203-e0a2" type="max"/>
      </constraints>
      <profiles>
        <profile id="71eb-24af-00e7-af86" name="Bite Attack" hidden="false" typeId="fa54-3872-dea1-df41" typeName="Melee Weapon">
          <characteristics>
            <characteristic name="Type" typeId="3f50-492d-96d0-69c5">Special</characteristic>
            <characteristic name="Strength" typeId="1439-1344-a602-f9d9">User x2</characteristic>
            <characteristic name="Ignores Sv" typeId="1439-1344-a602-f9d8">Yes</characteristic>
            <characteristic name="Abilities" typeId="a46d-26b2-96ab-913f">One bonus attack is made using this profile, striking last. If a non-monstrous creature multi-wound model suffers a wound from this attack they die automatically regardless of how many wounds they had as they are swallowed whole. Monstrous creatures instead suffer d3 wounds on a failed save as while they are too large to swallow whole, the massive jaws can still inflict terrible damage upon them.</characteristic>
          </characteristics>
        </profile>
        <profile id="1368-0b9a-a262-bd64" name="Stomp Attack" hidden="false" typeId="fa54-3872-dea1-df41" typeName="Melee Weapon">
          <characteristics>
            <characteristic name="Type" typeId="3f50-492d-96d0-69c5">2-H</characteristic>
            <characteristic name="Strength" typeId="1439-1344-a602-f9d9">User</characteristic>
            <characteristic name="Ignores Sv" typeId="1439-1344-a602-f9d8">Yes*</characteristic>
            <characteristic name="Abilities" typeId="a46d-26b2-96ab-913f">*Monstrous creatures are far too large to stomp effectively on, and thus still gain their save against the attacks.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="cfaa-655b-fd7e-404d" name="Terrifying" hidden="false">
          <description>Even the bravest of soldiers might falter in the face of a terrying Carnosaur barreling down at them. A unit that is sucessfully charged by a Carnosaur must pass a morale test or immediately flee. (The Carnosaur may sweeping advance the fleeing enemy, but must roll two d6 and discard the lowest dice roll as it&apos;s likely the craven defenders were already running when it reached their position.)</description>
        </rule>
        <rule id="a929-417f-a896-37e0" name="Shoot the Big One!" hidden="false">
          <description>The opposing player&apos;s line of fire is only blocked by terrain, vehicles and models in close combat while shooting at the Carnosaur, and do not need to make a leadership test to shoot at it if it&apos;s not the closest target.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="690b-7d8b-2c89-da77" name="Fearless" hidden="false" targetId="b137-13a1-eb97-c5e5" type="rule"/>
        <infoLink id="2405-2c9d-bde3-bfab" name="Exodite Carnosaur" hidden="false" targetId="3a86-404d-0fb6-5696" type="profile"/>
        <infoLink id="dea0-150e-1eda-4b8d" name="Laser Lance (Ranged)" hidden="false" targetId="9b89-7610-7e65-2b41" type="profile">
          <modifiers>
            <modifier type="set" field="name" value="Laser Lances"/>
            <modifier type="set" field="d3f6-19e8-ac9e-ae13" value="Assault 2"/>
          </modifiers>
        </infoLink>
