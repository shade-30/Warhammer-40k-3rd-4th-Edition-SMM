                            <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Eldar Grenade Launchers can fire either plasma or krak rounds. Choose which to shot before rolling to hit.
Units that take casualties from a plasma grenade must test for pinning.</characteristic>
                          </characteristics>
                        </profile>
                        <profile id="d42d-9b67-f45a-2ba7" name="Grenade Launcher (krak)" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Ranged Weapon">
