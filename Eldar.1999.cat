      <rules>
        <rule id="b99c-ac2a-8169-2fb9" name="Reckless" hidden="false">
          <description>Nuadhu ignores all &apos;crew stunned&apos; and &apos;crew shaken&apos; results on the Damage tables.</description>
        </rule>
        <rule id="98d8-35f1-e2bb-618d" name="Hit and Run" hidden="false">
          <description>Naudhu can make hit=and-run attacks just like an Eldar jetbike. This means he can always move 6&quot; in the assault phase, as long as he did not move more than 12&quot; in the movement phase.</description>
        </rule>
        <rule id="a5ce-5c76-f901-8b0a" name="Chief of the Wild Riders" hidden="false">
          <description>Any unit lead by Nuagha will never fall back and cannot be pinned.</description>
        </rule>
      </rules>
