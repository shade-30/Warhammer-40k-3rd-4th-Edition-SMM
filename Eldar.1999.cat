    <selectionEntry id="a4ef-a5f7-1009-a021" name="Avatar of the Bloody-Handed God" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="9250-0161-fd1e-6909" type="max"/>
      </constraints>
      <rules>
        <rule id="d069-fa96-bd87-fbb1" name="Inspiring" hidden="false">
          <description>Any Eldar unit with a model within 12&quot; of the Avatar become fearless in close combat. Also, if the Avatar is in close combat, all Eldar units with a model within 12&quot; add +1 to their score when determing who won a round of close combat.</description>
        </rule>
        <rule id="4557-3d8c-7f0f-7f4e" name="Daemon" hidden="false">
          <description>An Avatar is affected by weapons or abilites that use special rules against Daemons.</description>
        </rule>
      </rules>
      <infoLinks>
