    <selectionEntry id="341c-1d2c-25d8-af97" name="Ordo Hereticus Inquisitor" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set-primary" field="category" value="a8a7-7a4b-5f7e-2138">
          <conditions>
            <condition field="selections" scope="force" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="27ee-b0a2-0c2a-b518" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="61ef-7862-b33f-b2b1" type="max"/>
      </constraints>
      <rules>
        <rule id="bac2-b18e-c147-d36c" name="Iron Will" hidden="false">
          <description>An Inquisitor Lord can choose whether to pass or fail any Morale or Pinning test he is called upton to make. Even if failure is normally automatic, the Lord may still choose whether to pass or fail the test.</description>
        </rule>
      </rules>
      <infoLinks>
