    <selectionEntry id="75e8-963b-d44e-77cd" name="Arco-flagellants" hidden="false" collective="false" import="true" type="unit">
      <categoryLinks>
        <categoryLink id="9ba6-6d18-1d3a-65b5" name="New CategoryLink" hidden="false" targetId="6d25-b346-c314-6911" primary="true"/>
      </categoryLinks>
      <selectionEntryGroups>
        <selectionEntryGroup id="2a6c-1993-9631-1c8f" name="Flagellants" hidden="false" collective="false" import="true" defaultSelectionEntryId="6576-b963-bf8e-c61a">
          <constraints>
            <constraint field="selections" scope="parent" value="3.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d174-d4ec-c725-5762" type="min"/>
            <constraint field="selections" scope="parent" value="6.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="f81a-7634-d3a1-0410" type="max"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="6576-b963-bf8e-c61a" name="Arco-flagellant" hidden="false" collective="false" import="true" type="upgrade">
              <rules>
                <rule id="0317-e403-4bed-e7e4" name="Dangerous to Know" hidden="false">
                  <description>Arco-flagellants may not ride in vehicles. They cannot capture table quarters, objectives, or count as surviving troops in a Meat Grinder mission. In addition, no other models may ever join a unit of Arco-flagellants.</description>
                </rule>
                <rule id="8504-3b39-dcae-9018" name="Implant Injectors" hidden="false">
                  <description>The Arco-flagellant&apos;s stimm injectors can be activated at the beginning of any of the Witch Hunter&apos;s movement phases. For the remainder of the game they are subject to the Holy Rage (pg 24) rule. However, on a roll of 6 for additional movement remove a model as a casualty.
In close combat, roll a D6 at the beginning of each Assault phase to determine the number of Attacks it may make that phase, in additional to the bonus for assaulting that turn. Should a 6 be rolled, the model will be removed as a casualty at the end of the Assault phase after it resolves its attacks.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="4f72-82b2-effe-55c6" name="Fearless" hidden="false" targetId="b137-13a1-eb97-c5e5" type="rule"/>
                <infoLink id="f00a-4f15-303a-28df" name="Invulnerable Saving Throw" hidden="false" targetId="97b3-810d-a09e-872b" type="rule"/>
                <infoLink id="882d-2781-d12c-511b" name="Power Weapon" hidden="false" targetId="5774-7187-2616-dd8a" type="profile"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="35.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="0.0"/>
      </costs>
    </selectionEntry>
