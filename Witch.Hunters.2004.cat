    <selectionEntry id="0f63-46e5-f70b-23d5" name="Inquisitor Lord Karamazov" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="4aca-2267-d48f-97f4" value="0.0">
          <conditions>
            <condition field="4ed5-2f92-9abc-2870" scope="force" value="1500.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="any" type="lessThan"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4aca-2267-d48f-97f4" type="max"/>
      </constraints>
      <profiles>
        <profile id="2bac-5990-b9f1-a017" name="Sword of Justice" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon">
          <characteristics>
            <characteristic name="Range" typeId="deb8-131d-bdcf-1376">Melee</characteristic>
            <characteristic name="S" typeId="24d8-2110-08fa-d844">User</characteristic>
            <characteristic name="AP" typeId="25ce-028f-0aae-2855">1</characteristic>
            <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Melee</characteristic>
            <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Ignore Armour Saves. Master-crafted.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="a8a0-74af-0ea0-abf6" name="Iron Will" hidden="false">
          <description>An Inquisitor Lord can choose whether to pass or fail any Morale or Pinning test he is called upton to make. Even if failure is normally automatic, the Lord may still choose whether to pass or fail the test.</description>
        </rule>
        <rule id="fc65-55d8-31e2-9e28" name="Strength of Solitude" hidden="false">
          <description>Karamazov may not join friendly units and may be picked out by enemy shooters even if he is within 6&quot; of other targets.</description>
        </rule>
        <rule id="6730-6481-d74e-849f" name="Uncompromising" hidden="false">
          <description>All friendly units within 12&quot; of the inquisitor may re-roll failed Morale and Pinning tests. Note that where failure is automatic that this ability confers no benefit.</description>
        </rule>
        <rule id="1386-93a3-5a3e-24e4" name="Retinue" hidden="false">
          <description>Karamazov and his retinue are treated as one individual model, with a combined profile. Linked with the logister of the Throne of Judgement, Karamazov&apos;s Lexmechanic counts as two Sage Henchmen, and the Execution Servitor counts as a Gun Servitor that can fire its multi-melta even if Karamazov moves in the Movement phase.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="7ab6-9535-ec3d-99d6" name="Karamazov" hidden="false" targetId="9106-36a5-1c03-6e29" type="profile"/>
        <infoLink id="a38a-ee2e-70f6-7912" name="The Sage" hidden="false" targetId="a167-544a-1db8-c20a" type="rule"/>
        <infoLink id="5952-e070-142c-062f" name="The Warrior" hidden="false" targetId="d536-da50-2f8e-b9cf" type="rule">
