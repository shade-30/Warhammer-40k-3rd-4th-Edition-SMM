    <selectionEntry id="ed56-564f-d8bd-b514" name="Celestian Squad" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="cbac-d7ba-b399-9449" name="Faithful" hidden="false">
          <description>Add 1 Faith Point</description>
        </rule>
        <rule id="51fa-12c2-e73a-75d6" name="Holy Hatred" hidden="false">
          <description>Against enemy with a WS, Celestians hit on a 3+ regardless of respective WS values. This does not apply against Independent Characters or Monstrous Creatures.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="7671-e529-e74d-58af" name="New CategoryLink" hidden="false" targetId="6d25-b346-c314-6911" primary="true"/>
