    <selectionEntry id="2df0-ad0b-fe31-1d2c" name="Zealots (WD304)" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="e6d5-bc03-5827-d5da" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <rules>
        <rule id="e01b-7d3c-83d0-4e5f" name="&quot;Here comes the Pain&quot;" hidden="false">
          <description>Whenever a unit of Zealots is forced to take a Morale test, Pinning check or Leadership check for any rason, treat any negative modifiers as positive modifiers to their Leadership.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="b11f-7f7e-9e71-a1a6" name="Infantry" hidden="false" targetId="6953-6bba-0bb9-d49d" primary="false"/>
      </categoryLinks>
      <selectionEntries>
        <selectionEntry id="210b-10c6-bf4c-bf8b" name="Exterminators" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="increment" field="4ed5-2f92-9abc-2870" value="3.0">
              <repeats>
                <repeat field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="8514-f8d7-56dd-d3eb" repeats="1" roundUp="false"/>
              </repeats>
            </modifier>
          </modifiers>
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="42a5-4882-8466-ebde" type="max"/>
          </constraints>
          <profiles>
            <profile id="6ecf-e255-080d-ea20" name="Exterminators" hidden="false" typeId="b399-8a1b-bf0b-c5b7" typeName="Weapon">
              <characteristics>
                <characteristic name="Range" typeId="deb8-131d-bdcf-1376">Melee</characteristic>
                <characteristic name="S" typeId="24d8-2110-08fa-d844">4</characteristic>
                <characteristic name="AP" typeId="25ce-028f-0aae-2855">5</characteristic>
                <characteristic name="Type" typeId="d3f6-19e8-ac9e-ae13">Special</characteristic>
                <characteristic name="Abilities" typeId="492d-1f80-b777-26f2">Used once per battle in the first round of an assault in which the unit charged. Every model in the unit equipped with Exterminators make an extra attack resolved at Iniative 8 that hits on a 6+ using the Exterminator weapon profile. For every 5th model beyond the first (6, 11, 16+) the to hit roll is improved by 1 up to three times (5+, 4+, 3+).</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="0.0"/>
          </costs>
        </selectionEntry>
