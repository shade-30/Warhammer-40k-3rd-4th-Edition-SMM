          <rules>
            <rule id="4e2c-faec-71f4-f580" name="Holy Icon" hidden="false">
              <description>Any friendly unit with a model within 6&quot; of the vehicle adds 1 to its Leadership for the purposes of taking any Morale checks or Pinning tests.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10.0"/>
