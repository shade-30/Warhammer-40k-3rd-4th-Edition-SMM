    <selectionEntry id="81bd-6c77-4ed1-ea44" name="Penitent Engines" hidden="false" collective="false" import="true" type="unit">
      <categoryLinks>
        <categoryLink id="299e-d9cd-8c04-7552" name="New CategoryLink" hidden="false" targetId="aacb-8a81-62c0-3db8" primary="true"/>
      </categoryLinks>
      <selectionEntryGroups>
        <selectionEntryGroup id="8ee7-f7e6-07e3-2c50" name="Penitents" hidden="false" collective="false" import="true" defaultSelectionEntryId="a881-dcd2-77b1-928d">
          <constraints>
            <constraint field="selections" scope="parent" value="3.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b85f-6436-10e2-781b" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c4c5-e09f-006e-f839" type="min"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="a881-dcd2-77b1-928d" name="Penitent Engine" hidden="false" collective="false" import="true" type="upgrade">
              <rules>
                <rule id="e029-faa7-131a-6337" name="Battle Frenzy" hidden="false">
                  <description>The Penitent Engine must always fire its weapons if able to do so, and must always attempt to cover as many targets as possible with the Flamer template. Once in base-to-base contact, each Penitent Engine rolls at the beginning of every Assault phase to determine the number of attacks.</description>
                </rule>
                <rule id="a590-e7a7-5110-b2c5" name="Holy Rage" hidden="false">
                  <description>Penitent Engines are subject to the Holy Rage rule (pg 24).</description>
                </rule>
                <rule id="cca5-2cb9-3e7c-f4b5" name="Rampage" hidden="false">
                  <description>Penitent Engines ignore any Crew Shaken and Crew Stunned results.</description>
                </rule>
              </rules>
              <infoLinks>
                <infoLink id="10e3-a5aa-fcd6-c816" name="Penitent Engine" hidden="false" targetId="93f1-bde6-2396-6fdd" type="profile"/>
                <infoLink id="fb6f-553f-b8e2-bb3e" name="Dreadnought Close Combat Weapons" hidden="false" targetId="c7f7-e5ab-17a7-1cf9" type="profile"/>
                <infoLink id="59db-230f-3696-c36e" name="Heavy Flamer" hidden="false" targetId="6d36-2c09-dfc3-f257" type="profile"/>
                <infoLink id="7cc0-2bc1-e5f6-9fc0" name="Open-Topped" hidden="false" targetId="4795-fd7c-2846-78ba" type="rule"/>
              </infoLinks>
              <costs>
                <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="80.0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <costs>
        <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="0.0"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="6b62-c09c-fb16-cdf1" name="Orbital Strike" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="dcca-65ae-5e4c-8832" name="Inaccuracy" hidden="false">
          <description>An Orbital Strike scatters just like ordinary ordnance weapons, except when a miss is rolled the distance scatterd is double the number scored on the D6. If a hit is rolled, the template deviates by the distance shown on the Hit Symbol.</description>
        </rule>
        <rule id="e7db-9c2a-8bd0-eb8f" name="Pinning" hidden="false">
          <description>All Orbital Strikes cause Pinning tests</description>
        </rule>
        <rule id="4b1a-f0d9-db79-97f1" name="Placement" hidden="false">
          <description>The Ordnance Blast marker for the strike must be placed anywhere within the specified terrain piece</description>
        </rule>
        <rule id="25c6-31b6-bd84-838c" name="Plotting" hidden="false">
          <description>The Orbital Strike must be keyed to a specific piece of terrain at the start of the battle. Make a note of the plotted target before forces are deployed but after deployment zones have been determined</description>
        </rule>
        <rule id="63da-5aee-73a9-01de" name="Timing" hidden="false">
          <description>An orbital strike uses the Reserve special rule to determine when it strikes. Once the orbital strike passes the Reserve roll it fires each Space Marine shooting phases for the rest of the game. It cannot be stopped once started. The Space Marine player can opt to not roll for the onset of the orbital strike if they wish.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="bd85-0a5e-84fa-6310" name="Heavy Support" hidden="false" targetId="aacb-8a81-62c0-3db8" primary="true"/>
      </categoryLinks>
      <selectionEntryGroups>
        <selectionEntryGroup id="d7f8-ef0e-709a-32b9" name="Strike" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="c4f7-aecb-8e87-632f" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="aefd-e08b-58b0-1e7b" type="min"/>
