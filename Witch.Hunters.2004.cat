        <categoryLink id="e28a-e1b1-9751-5c68" name="Independent Character" hidden="false" targetId="3c96-248b-affd-e504" primary="false"/>
      </categoryLinks>
      <selectionEntries>
        <selectionEntry id="3adf-82c9-2af9-31f3" name="Priest" hidden="false" collective="false" import="true" type="model">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="43be-aa30-febc-f629" type="min"/>
            <constraint field="selections" scope="parent" value="5.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="af47-f872-95fa-d491" type="max"/>
          </constraints>
          <rules>
            <rule id="e918-6fbe-99bc-946c" name="Attachment" hidden="false">
              <description>Priests must always be attached to other units,. and only one may be attached to each. Priests may be attacked to the following units: Celestians, Battle Sister Squads, Inquisitorial Strom Troops (and Adeptus Arbites), Dominions, Sisters Repentia, Inducted Imperial Guard Infantry Squads, or Inducted Imperial Guard Armoured Fist Squads.</description>
            </rule>
            <rule id="aea0-c6f5-78a2-5897" name="Fanatical" hidden="false">
              <description>A Priest and the unit he is assigned to may re-roll any failed to hit rolls once in the turn they charge while the Priest lives.</description>
            </rule>
            <rule id="ce4f-c655-03b8-dce4" name="Righteous Fury" hidden="false">
              <description>A unit including a Priest must charge in the Assault phase if there is an enemy in reach. In addition, such is the state of agitation that they always count as moving even if the models are stationary, so would be unable to fire heavy weapons.</description>
            </rule>
          </rules>
          <infoLinks>
            <infoLink id="d786-8d6b-8a09-3919" name="Laspistol" hidden="false" targetId="95a9-d270-d218-1772" type="profile"/>
            <infoLink id="37fa-b6ef-93a0-b6d6" name="Close Combat Weapon" hidden="false" targetId="46d5-85f2-d932-f0a2" type="profile"/>
            <infoLink id="36a5-29f4-b26a-f442" name="Priest" hidden="false" targetId="439e-b06f-40b3-44cb" type="profile"/>
          </infoLinks>
