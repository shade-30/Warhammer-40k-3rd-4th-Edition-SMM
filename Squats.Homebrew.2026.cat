    <selectionEntry id="zaba-97ee-9f04-1e25" name="Living Ancestor" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="3d5e-5a46-32a5-dbdb" name="Mending Hands" hidden="false">
          <description>The physic powers of the Ancestor allows them to ignore the first failed saving throw each turn in the unit containing the Ancestor. This may not be used on any model who suffered &apos;Instant Death&apos; or hit by a weapon that allows no saves. It cannot be used if the Ancestor is in base to base contact with an enemy model.</description>
        </rule>
        <rule id="ded2-ec87-c22e-d219" name="Conversion Field" hidden="false">
          <description>Gain a 4+ invulnerable save</description>
        </rule>
      </rules>
      <infoLinks>
