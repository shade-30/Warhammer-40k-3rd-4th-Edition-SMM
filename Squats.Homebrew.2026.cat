    <selectionEntry id="2530-bdce-c4ed-6b36" name="Iron Eagle Gyrocopter" hidden="false" collective="false" import="true" type="upgrade">
      <rules>
        <rule id="b2ec-9c04-47de-2db6" name="Jammed!" hidden="false">
          <description>If a double is ever rolled when determining the amount of shots the Rotary Cannon fires, the feed system has jammed up and it counts as being destroyed for the rest of the game.</description>
        </rule>
        <rule id="d7e6-8fac-0be4-fe1f" name="Tail Gunner" hidden="false">
          <description>The twin-linked rotary cannon may fire at a different target than the lascannon.</description>
        </rule>
      </rules>
