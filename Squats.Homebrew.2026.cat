                        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="fd9c-73f6-3fee-99c3" type="max"/>
                      </constraints>
                      <rules>
                        <rule id="60a6-30c0-f7a8-75d9" name="Blessing of the Machine-God" hidden="false">
                          <description>If the Enginseer starts the turn in contact with a damaged vehicle he may attempt to make a repair. If the vehicle is Immoblisied or has a Weapon Destroyed, one of these is repaired on a roll of 6+. The Techpriest gains +1 on this roll for each Technical Servitor he has with him.</description>
                        </rule>
                      </rules>
                      <infoLinks>
                        <infoLink id="9cb5-2dc8-2246-c75a" name="Techpriest Enginseers" hidden="false" targetId="24b8-23fd-ef52-ec97" type="profile"/>
