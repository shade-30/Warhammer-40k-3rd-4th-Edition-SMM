    <selectionEntry id="3e9c-f3f1-1647-b580" name="Sky Ray Missile Defence Gunship" hidden="false" collective="false" import="true" type="unit">
      <rules>
        <rule id="a268-ef1f-b062-f938" name="Landing Gear" hidden="false">
          <description>The Sky Ray make opt to set down at the beginning of its Movement phase, choosing to remain stationary that turn and to no longer count as a Skimmer. </description>
        </rule>
