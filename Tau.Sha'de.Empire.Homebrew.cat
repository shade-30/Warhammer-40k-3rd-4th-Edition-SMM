    <profile id="1e67-864e-5496-ce33" name="XV25 Stealth Suit Shas&apos;ui" hidden="false" typeId="1e16-2bd8-7cad-379b" typeName="Unit">
      <characteristics>
        <characteristic name="WS" typeId="c704-6128-f143-935a">2</characteristic>
