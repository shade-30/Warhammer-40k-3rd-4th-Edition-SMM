        <rule id="5186-b94a-6a62-a770" name="Small Target" hidden="false">
          <description>Nurglings&apos; cover save is at +1. They do not block line of sight to anything behind them.</description>
        </rule>
        <rule id="e2a8-7e34-d8ae-94b8" name="Vulnerable to Blasts" hidden="false">
          <description>Template, Ordnance and Blast marker weapons inflict two wounds instead of one on nurglings.</description>
        </rule>
        <rule id="c6ec-af88-a521-b731" name="Mischievous" hidden="false">
          <description>Nurglings may never hold table quarters or objectives</description>
