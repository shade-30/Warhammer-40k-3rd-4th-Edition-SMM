    <selectionEntry id="5186-e8d8-39e1-5ee1" name="Renegade Tarantula" hidden="false" collective="false" import="true" type="upgrade">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" childId="3261-6601-5bfe-f5d0" type="equalTo"/>
          </conditions>
        </modifier>
      </modifiers>
      <rules>
        <rule id="5de3-b9d2-fbcb-52a0" name="Firing Modes" hidden="false">
          <description>At deployment, you must select a firing mode. It cannot be changed once the game begins.

Point Defence Mode: Choose a fixed 90 degree arc. The gun will engage enemy targets up to 24&quot; away within the arc.

Sentry Mode: The gun will fire at the nearest enemy target within 12&quot; that it can see.</description>
        </rule>
        <rule id="b170-d2ed-d202-8ac5" name="Targetting Priority" hidden="false">
          <description>A heavy bolter Sentry gun will fire at the nearest non-vehicle unit it can hit. A lascannon Sentry gun will fire at the closest enemy vehicle it can hit. If no preferred target can be hit they will shoot at non-preferred targets. </description>
        </rule>
        <rule id="6ba3-42dd-910e-4789" name="Damage" hidden="false">
          <description>A Tarantula is destroyed by any glancing or penetrating hit.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="8dae-cff7-a965-2981" name="Immobile" hidden="false" targetId="de3d-c21c-3d4f-5259" type="rule"/>
