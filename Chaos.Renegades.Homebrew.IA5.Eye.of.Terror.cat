        <selectionEntryGroup id="3f0e-a6e3-5df5-5e09" name="Hunting Lance" hidden="false" collective="false" import="true">
          <modifierGroups>
            <modifierGroup>
              <comment>This logic may seem odd. What happens is that when # of RRs is 5, the max number of lances shoots up to 9. By subtracting by 4 when we reach five, we counteract the fact it adds in four extra lances. We cannot set the max to 0 because it does not display the option to select lances without it being a max &gt; 0.</comment>
              <modifiers>
                <modifier type="increment" field="6f5c-6ce6-59e6-9092" value="1.0">
                  <repeats>
                    <repeat field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="45a5-a366-2450-d431" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
                <modifier type="decrement" field="6f5c-6ce6-59e6-9092" value="1.0">
                  <repeats>
                    <repeat field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="true" childId="7f02-5378-e9b5-943e" repeats="1" roundUp="false"/>
                  </repeats>
                </modifier>
              </modifiers>
            </modifierGroup>
          </modifierGroups>
          <constraints>
            <constraint field="selections" scope="parent" value="4.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6f5c-6ce6-59e6-9092" type="max"/>
          </constraints>
          <selectionEntries>
