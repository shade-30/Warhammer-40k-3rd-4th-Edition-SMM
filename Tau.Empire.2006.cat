    <selectionEntry id="tau0-70f6-a3a9-33ad" name="Commander Farsight" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="hidden" value="true">
          <conditions>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="6f3a-0dbb-8234-e5fe" type="equalTo"/>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="728e-a13e-a007-79c2" type="equalTo"/>
            <condition field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="3e47-7e31-91e6-f81b" type="equalTo"/>
          </conditions>
        </modifier>
        <modifier type="set" field="54d2-74c5-ce38-d70f" value="0.0">
          <conditions>
            <condition field="4ed5-2f92-9abc-2870" scope="force" value="1500.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="any" type="lessThan"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="54d2-74c5-ce38-d70f" type="max"/>
      </constraints>
      <rules>
        <rule id="c57b-13b0-d643-6b04" name="Dawn Blade" hidden="false">
          <description>Farsight counts as a Monstrous Creature in hand-to-hand combat, so he ignores Armour Saves and rolls 2D6+S for Armour Penetration against vehicles.</description>
        </rule>
        <rule id="9744-1e90-b3ef-b469" name="Ork Fighter" hidden="false">
          <description>Any Tau model nit in an army led by Farsight count as having the Preferred Enemy special rule when fighting Orks (Always hits on a 4+ in combat)</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="tau1-65ab-90a9-0b8c" name="Commander Farsight" hidden="false" targetId="tau0-7b3c-f374-5939" type="profile"/>
        <infoLink id="tau1-d65a-5db7-3085" name="Special Character" hidden="false" targetId="tau0-be8a-8bae-1dcd" type="rule"/>
      </infoLinks>
      <categoryLinks>
