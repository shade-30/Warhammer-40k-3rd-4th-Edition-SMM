      </constraints>
      <rules>
        <rule id="1607-ea2c-27f0-885b" name="Forward Scouts" hidden="false">
          <description>In scenarioes where some troops start in reserve and others on the table, Pathfinders always deploy on the table. Pathfinders may make a normal move after deployment but before the first turn. This move may include disembarking from the Devilfish.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="tau1-e993-e91d-421f" name="New CategoryLink" hidden="false" targetId="34e2-d53c-28ab-44cf" primary="true"/>
