      </modifiers>
      <rules>
        <rule id="ebe8-27a0-f92a-aace" name="Gun Drone Squadron" hidden="false">
          <description>A Gun Drone squadron has its processors linked to enable it to have the capacity for independent action. They are programmed for self-preservation and take Leadership tests normally. If their numbers are reduced to less than 4 their Leadership drops to 4.</description>
        </rule>
      </rules>
