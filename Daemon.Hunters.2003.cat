          </constraints>
          <rules>
            <rule id="e8fa-b815-7054-f0b8" name="Digital Weapons" hidden="false">
              <description>A model with digital weapons may make a special attack in close combat at +2 to his Initiative in addition to his normal attacks, inflicting one S 4 hit on a D6 roll of 4+</description>
            </rule>
          </rules>
