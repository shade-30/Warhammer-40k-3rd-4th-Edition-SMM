          </constraints>
          <rules>
            <rule id="6dcf-162f-a7dd-9916" name="Blessed" hidden="false">
              <description>Grey Knight vehicles with this upgrade gain +1 to their armour penetration against enemy vehicles with the following upgardes: Daemonic Possession, Mutated Hull, Living Vehicle and/or Parasitic Possession.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="829e-82ee-72b9-61eb" name="Psycannon Bolts" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditionGroups>
                <conditionGroup type="and">
                  <conditions>
                    <condition field="selections" scope="ancestor" value="0.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="2984-3183-a9c0-7270" type="notInstanceOf"/>
