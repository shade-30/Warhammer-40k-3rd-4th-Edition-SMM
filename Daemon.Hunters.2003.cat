    <selectionEntry id="c1a4-d583-521f-064b" name="Orbital Strike" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bc5d-c516-7646-b659" type="max"/>
      </constraints>
      <rules>
        <rule id="15d1-149e-dce2-5c6f" name="Inaccuracy" hidden="false">
          <description>An Orbital Strike scatters just like ordinary ordnance weapons, except when a miss is rolled the distance scatterd is double the number scored on the D6. If a hit is rolled, the template deviates by the distance shown on the Hit Symbol.</description>
        </rule>
        <rule id="79a0-1024-6410-e398" name="Pinning" hidden="false">
          <description>All Orbital Strikes cause Pinning tests</description>
        </rule>
        <rule id="53ce-1374-fb3a-e28e" name="Placement" hidden="false">
          <description>The Ordnance Blast marker for the strike must be placed anywhere within the specified terrain piece</description>
        </rule>
        <rule id="d863-9865-e6a2-8555" name="Plotting" hidden="false">
          <description>The Orbital Strike must be keyed to a specific piece of terrain at the start of the battle. Make a note of the plotted target before forces are deployed but after deployment zones have been determined</description>
        </rule>
        <rule id="84a4-8695-b292-f477" name="Timing" hidden="false">
          <description>An orbital strike uses the Reserve special rule to determine when it strikes. Once the orbital strike passes the Reserve roll it fires each Space Marine shooting phases for the rest of the game. It cannot be stopped once started. The Space Marine player can opt to not roll for the onset of the orbital strike if they wish.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink id="5786-bc0c-be2a-7302" name="New CategoryLink" hidden="false" targetId="aacb-8a81-62c0-3db8" primary="true"/>
      </categoryLinks>
      <selectionEntryGroups>
        <selectionEntryGroup id="3ae2-0f8e-326e-4cf3" name="Orbital Strike Type" hidden="false" collective="false" import="true">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4083-9d3d-953c-8ea8" type="max"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8ab1-0413-e789-717f" type="min"/>
