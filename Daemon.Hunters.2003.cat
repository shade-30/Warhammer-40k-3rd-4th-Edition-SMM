          </constraints>
          <rules>
            <rule id="fcac-dce6-4d2c-afc8" name="Psycannon Bolts" hidden="false">
              <description>The vehicle&apos;s bolters are upgraded to AP 4 and ignore invulnerable saves.</description>
            </rule>
          </rules>
          <costs>
            <cost name="pts" typeId="4ed5-2f92-9abc-2870" value="10.0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="c1db-e5cf-fe79-46d0" name="Sacred Hull" hidden="false" collective="false" import="true" type="upgrade">
          <modifiers>
            <modifier type="set" field="hidden" value="true">
              <conditionGroups>
