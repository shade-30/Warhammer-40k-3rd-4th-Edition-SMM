    <selectionEntry id="2e61-10ad-9bf7-bd39" name="Brother-Captain Stern" hidden="false" collective="false" import="true" type="unit">
      <modifiers>
        <modifier type="set" field="e38a-abb3-d8c2-9f48" value="0.0">
          <conditions>
            <condition field="4ed5-2f92-9abc-2870" scope="force" value="1500.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" childId="any" type="lessThan"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint field="selections" scope="force" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e38a-abb3-d8c2-9f48" type="max"/>
      </constraints>
      <rules>
        <rule id="d35c-9cf1-1396-3483" name="The Strands of Fate" hidden="false">
          <description>Stern may re-roll one dice roll per phase. Keep track of the number of times Stern uses this ability in a given player turn. His opponent may subsequently re-roll one of his own units&apos; dice per use of this ability. Any re-rolls garnered in this way that are not utilised by the end of the player turn are lost.</description>
        </rule>
        <rule id="c451-7c48-58bd-24ab" name="Daemonic Nemesis" hidden="false">
          <description>Any opponent using the Adversaries rules may upgrade their Greater Daemon to Chaos to a Lord of Change for no extra cost.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="78e5-3b86-1d97-f7b8" name="Stern" hidden="false" targetId="2d38-ca9d-e0e8-2ebd" type="profile"/>
