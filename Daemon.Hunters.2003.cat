    <selectionEntryGroup id="0563-f3dc-3db7-5c09" name="Daemon Hunters Vehicle Upgrades" hidden="false" collective="false" import="true">
      <selectionEntries>
        <selectionEntry id="3dd4-be65-9b0a-077e" name="Extra Armor" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="4e00-2072-b8af-3d5b" type="max"/>
          </constraints>
          <rules>
            <rule id="fd4d-889f-a6ce-5575" name="Extra Armour" hidden="false">
              <description>Treat &apos;Crew Stunned&apos; results as &apos;Crew Shakeen&apos; instead.</description>
